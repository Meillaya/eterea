{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Eterea",
  "version": "0.1.0",
  "identifier": "com.eterea.desktop",
  "build": {
    "beforeDevCommand": { "script": "bun run dev", "cwd": "../src/frontend" },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": { "script": "bun run build", "cwd": "../src/frontend" },
    "beforeBundleCommand": { "script": "bash scripts/prepare-linuxdeploy.sh", "cwd": ".." },
    "frontendDist": "../src/frontend/build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Eterea",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "base-uri": "'self'",
        "form-action": "'self'",
        "object-src": "'none'",
        "frame-src": "'none'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost https://asset.localhost data: blob: https:",
        "media-src": "'self' asset: http://asset.localhost https://asset.localhost data: blob: https:",
        "font-src": "'self' data:",
        "connect-src": "'self' ipc: http://ipc.localhost https://ipc.localhost"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "useLocalToolsDir": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
